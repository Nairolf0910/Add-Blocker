{
  "manifest_version": 3,
  "name": "Redirect Guard",
  "version": "1.2.0",
  "description": "Blocks unwanted redirects to scam and ad pages automatically. Suspicious tabs are closed instantly. You decide where you go.",
  "permissions": [
    "webNavigation",
    "declarativeNetRequest",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Redirect Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "test.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
